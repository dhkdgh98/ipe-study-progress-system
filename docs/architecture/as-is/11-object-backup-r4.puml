!include _style.puml
title AS-IS 11 — UML 객체: 제공된 revision 4 백업
left to right direction

object "revision4 : Payload" as R4 {
  version = 2
  format = <absent>
  schemaVersion = <absent>
  payloadHash = <absent>
  fileBytes = 66601
}

object "app : AppState" as App {
  progressItems = 27
  noteItems = 0
  settings.targetV2 = present
}

object "atlas : AtlasState" as Atlas {
  concepts = 0
  frames = 0
  objects = 0
  keywords = 0
}

object "bridge : BridgeState" as Bridge {
  activeLinks = 148
  orphanedLinks = 47
  catalogItems = 157
}

object "activeLinks[*]" as Active {
  role = "핵심" x 148
  missingItemId = 0
  missingConceptId = 0
}

object "orphanedLinks[*]" as Orphans {
